<group name="malware_behavior_detection_generator,">
  <rule id="100830" level="7">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.commandLine">urlhaus_30_payload\.bin --urlhaus-validation</field>
    <field name="win.eventdata.image">urlhaus_30_payload.bin</field>
    <description>Process created: urlhaus_30_payload.bin (urlhaus_30_payload.bin --urlhaus-validation)</description>
    <group>sysmon,process_creation,</group>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>
  <rule id="109346" level="10">
    <decoded_as>json</decoded_as>
    <description>File dropped to user-accessible path: C:\Users\Public\Downloads\urlhaus_30_payload.bin</description>
    <group>sysmon,file_event,</group>
    <field name="win.eventdata.targetFilename">C:\\Users\\Public\\Downloads\\urlhaus_30_payload\.bin</field>
    <field name="win.system.eventID">11</field>
    <mitre>
      <id>T1105</id>
    </mitre>
  </rule>
  <rule id="109451" level="7">
    <decoded_as>json</decoded_as>
    <description>DNS lookup observed: mdftw8lo.btyek.website</description>
    <group>sysmon,dns,</group>
    <field name="win.eventdata.queryName">mdftw8lo\.btyek\.website</field>
    <field name="win.system.eventID">22</field>
    <mitre>
      <id>T1071.004</id>
    </mitre>
  </rule>
  <rule id="114363" level="7">
    <decoded_as>json</decoded_as>
    <description>HTTP connection observed: https://mdftw8lo.btyek.website/?ublib=bf723810-216b-4253-949d-cd83a30499d4</description>
    <group>sysmon,network_connection,</group>
    <field name="win.eventdata.destinationHostname">mdftw8lo\.btyek\.website</field>
    <field name="win.system.eventID">3</field>
    <mitre>
      <id>T1071.001</id>
    </mitre>
  </rule>
</group>