<group name="malware_behavior_detection_generator,">
  <rule id="112659" level="7">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.commandLine">urlhaus_24_payload\.sh --urlhaus-validation</field>
    <field name="win.eventdata.image">urlhaus_24_payload.sh</field>
    <description>Process created: urlhaus_24_payload.sh (urlhaus_24_payload.sh --urlhaus-validation)</description>
    <group>sysmon,process_creation,</group>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>
  <rule id="106333" level="10">
    <decoded_as>json</decoded_as>
    <description>File dropped to user-accessible path: C:\Users\Public\Downloads\urlhaus_24_payload.sh</description>
    <group>sysmon,file_event,</group>
    <field name="win.eventdata.targetFilename">C:\\Users\\Public\\Downloads\\urlhaus_24_payload\.sh</field>
    <field name="win.system.eventID">11</field>
    <mitre>
      <id>T1105</id>
    </mitre>
  </rule>
  <rule id="117321" level="7">
    <decoded_as>json</decoded_as>
    <description>IP connection observed: 85.204.125.67</description>
    <group>sysmon,network_connection,</group>
    <field name="win.eventdata.destinationIp">85\.204\.125\.67</field>
    <field name="win.system.eventID">3</field>
    <mitre>
      <id>T1071</id>
    </mitre>
  </rule>
  <rule id="116049" level="7">
    <decoded_as>json</decoded_as>
    <description>HTTP connection observed: http://85.204.125.67:8080/payload.sh</description>
    <group>sysmon,network_connection,</group>
    <field name="win.eventdata.destinationIp">85\.204\.125\.67</field>
    <field name="win.system.eventID">3</field>
    <mitre>
      <id>T1071.001</id>
      <id>T1571</id>
    </mitre>
  </rule>
</group>