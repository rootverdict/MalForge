    <group>sysmon,network_connection,</group>
    <field name="win.eventdata.destinationHostname">squvbf6p\.btyek\.one</field>
    <field name="win.system.eventID">3</field>
    <mitre>
      <id>T1071.001</id>
    </mitre>
  </rule>
</group>