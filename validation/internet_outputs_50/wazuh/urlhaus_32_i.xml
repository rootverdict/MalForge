<group name="malware_behavior_detection_generator,">
  <rule id="102058" level="7">
    <decoded_as>json</decoded_as>
    <description>Process created: urlhaus_32_i (urlhaus_32_i --urlhaus-validation)</description>
    <group>linux,auditd,process_creation,</group>
    <field name="audit.command">urlhaus_32_i --urlhaus-validation</field>
    <field name="audit.exe">urlhaus_32_i</field>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>
  <rule id="104177" level="10">
    <decoded_as>json</decoded_as>
    <description>File dropped to user-accessible path: /tmp/urlhaus_32_i</description>
    <group>linux,auditd,file_event,</group>
    <field name="audit.file.path">urlhaus_32_i</field>
    <mitre>
      <id>T1105</id>
    </mitre>
  </rule>
  <rule id="116029" level="7">
    <decoded_as>json</decoded_as>
    <description>IP connection observed: 182.120.9.25</description>
    <group>linux,network_connection,</group>
    <field name="dstip">182\.120\.9\.25</field>
    <mitre>
      <id>T1071</id>
    </mitre>
  </rule>
