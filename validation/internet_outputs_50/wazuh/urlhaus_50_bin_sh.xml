<group name="malware_behavior_detection_generator,">
  <rule id="108219" level="7">
    <decoded_as>json</decoded_as>
    <description>Process created: urlhaus_50_bin.sh (urlhaus_50_bin.sh --urlhaus-validation)</description>
    <group>linux,auditd,process_creation,</group>
    <field name="audit.command">urlhaus_50_bin\.sh --urlhaus-validation</field>
    <field name="audit.exe">urlhaus_50_bin\.sh</field>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>
  <rule id="108160" level="10">
    <decoded_as>json</decoded_as>
    <description>File dropped to user-accessible path: /tmp/urlhaus_50_bin.sh</description>
    <group>linux,auditd,file_event,</group>
    <field name="audit.file.path">urlhaus_50_bin\.sh</field>
    <mitre>
      <id>T1105</id>
    </mitre>
  </rule>
  <rule id="106669" level="7">
    <decoded_as>json</decoded_as>
    <description>IP connection observed: 112.239.101.142</description>
    <group>linux,network_connection,</group>
    <field name="dstip">112\.239\.101\.142</field>
    <mitre>
      <id>T1071</id>
    </mitre>
  </rule>
  <rule id="118186" level="7">
    <decoded_as>json</decoded_as>
    <description>HTTP connection observed: http://112.239.101.142:35487/bin.sh</description>
    <group>linux,network_connection,</group>
    <field name="dstip">112\.239\.101\.142</field>
    <field name="url">http://112\.239\.101\.142:35487/bin\.sh</field>
    <mitre>
      <id>T1071.001</id>
      <id>T1571</id>
    </mitre>
  </rule>
</group>