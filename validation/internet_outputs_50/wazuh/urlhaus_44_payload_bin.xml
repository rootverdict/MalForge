<group name="malware_behavior_detection_generator,">
  <rule id="114223" level="7">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.commandLine">urlhaus_44_payload\.bin --urlhaus-validation</field>
    <field name="win.eventdata.image">urlhaus_44_payload.bin</field>
    <description>Process created: urlhaus_44_payload.bin (urlhaus_44_payload.bin --urlhaus-validation)</description>
    <group>sysmon,process_creation,</group>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>
  <rule id="114722" level="10">
    <decoded_as>json</decoded_as>
    <description>File dropped to user-accessible path: C:\Users\Public\Downloads\urlhaus_44_payload.bin</description>
    <group>sysmon,file_event,</group>
    <field name="win.eventdata.targetFilename">C:\\Users\\Public\\Downloads\\urlhaus_44_payload\.bin</field>
    <field name="win.system.eventID">11</field>
    <mitre>
      <id>T1105</id>
    </mitre>
  </rule>
  <rule id="104560" level="7">
    <decoded_as>json</decoded_as>
    <description>DNS lookup observed: squvbf6p.btyek.one</description>
